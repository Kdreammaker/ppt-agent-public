      ],
      "text_slots": {
        "footer_note": "Template system sample"
      }
    },
    {
      "layout": "template_slide",
      "slide_selector": {
        "purpose": "summary",
        "scope": "sales",
        "preferred_variant": "summary/service-intro-cards",
