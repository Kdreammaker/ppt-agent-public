        "fallback_variants": [
          "cover/finance-sales",
          "cover/right-hero"
        ]
      },
      "text_values": [
        "Sales Deck Demo",
        "Exact-scope sales cover selected before generic fallback."
      ],
      "text_slots": {
        "footer_note": "Template system sample"
      }
    },
    {
      "layout": "template_slide",
      "slide_selector": {
        "purpose": "toc",
        "scope": "sales",
        "preferred_variant": "toc/visual-tiles",
        "fallback_variants": [
          "toc/simple-index"
        ]
      },
      "text_values": [
        "Sales Route",
        "Sales scope falls back to generic TOC slides",
        "Problem",
        "Approach",
