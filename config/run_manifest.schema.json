{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "run_manifest.schema.json",
  "title": "Run-scoped PPT output manifest",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "run_id",
    "created_at",
    "source",
    "bundle",
    "validation_results",
    "known_caveats",
    "input_spec_path",
    "output_deck_path",
    "run_deck_path",
    "run_spec_path",
    "report_paths"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input_spec_path", "output_deck_path"],
      "properties": {
        "input_spec_path": {
          "$ref": "#/$defs/base_relative_path"
        },
        "output_deck_path": {
          "$ref": "#/$defs/base_relative_path"
        }
      }
    },
    "bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_root", "deck_path", "spec_path", "report_paths", "preview_paths"],
      "properties": {
        "run_root": {
          "$ref": "#/$defs/base_relative_path"
        },
        "deck_path": {
          "$ref": "#/$defs/base_relative_path"
        },
        "spec_path": {
          "$ref": "#/$defs/base_relative_path"
        },
        "report_paths": {
          "$ref": "#/$defs/base_relative_path_list"
        },
        "preview_paths": {
          "$ref": "#/$defs/base_relative_path_list"
        }
      }
    },
    "validation_results": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "known_caveats": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "input_spec_path": {
      "$ref": "#/$defs/base_relative_path"
    },
    "output_deck_path": {
      "$ref": "#/$defs/base_relative_path"
    },
    "run_deck_path": {
      "$ref": "#/$defs/base_relative_path"
    },
    "run_spec_path": {
      "$ref": "#/$defs/base_relative_path"
    },
    "report_paths": {
      "$ref": "#/$defs/base_relative_path_list"
    }
  },
  "$defs": {
    "base_relative_path": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "^(?:[A-Za-z]:|/|\\\\|\\.\\.)"
      },
      "pattern": "^[^\\\\]+$"
    },
    "base_relative_path_list": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/base_relative_path"
      }
    }
  }
}
