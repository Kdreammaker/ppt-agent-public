      ]
    },
    "palette_recommendation": {
      "status": "mocked",
      "recommendation_type": "palette",
      "recommendations": [
        {
          "asset_class": "palette",
          "palette_hint": "navy_orange_high_contrast",
          "rationale": "B49 DNA shows finance/report templates have stronger hierarchy with navy plus accent color."
        }
      ]
    },
    "asset_class_recommendation": {
      "status": "mocked",
      "recommendation_type": "asset_class",
      "recommendations": [
        {
          "asset_class": "image",
          "policy": "user_supplied_or_generated_only",
          "rationale": "Image slots remain placeholders; no raw local folder scan or binary materialization."
        }
      ]
    },
    "review_suggestion": {
      "status": "mocked",
      "recommendation_type": "review_action",
      "recommendations": [
        {
          "action": "prefer_medium_density_first_beta_demo",
          "rationale": "B49 quality gap summary found dense and low-foreground slides in the current golden path."
        }
      ]
    }
  },
  "fixtures": [
    {
      "name": "valid_metadata_only_business_growth",
      "expected": "valid"
    },
    {
      "name": "reject_full_spec_payload",
      "expected": "invalid",
      "extra_request_fields": {
        "full_spec_json": {
          "name": "should not be sent"
        }
      }
    },
    {
      "name": "reject_generated_html_payload",
      "expected": "invalid",
      "extra_request_fields": {
        "generated_html_document": "<html>forbidden</html>"
      }
