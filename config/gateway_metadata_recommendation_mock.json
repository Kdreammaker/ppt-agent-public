      "status": "mocked",
      "recommendation_type": "template_family",
      "recommendations": [
        {
          "template_family": "production_ready_sales_finance",
          "rationale": "Matches analytical business deck with production-ready B49 DNA summaries.",
          "requires_entitlement": false
