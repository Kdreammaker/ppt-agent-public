{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Kdreammaker/template-based-ppt-system-with-ai/project_manifest.schema.json",
  "title": "Project-scoped PPT output bundle manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project_id",
    "created_at",
    "source",
    "bundle",
    "validation_results",
    "known_caveats"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_spec_path",
        "output_deck_path"
      ],
      "properties": {
        "input_spec_path": {
          "$ref": "#/$defs/base_relative_path"
        },
        "output_deck_path": {
          "$ref": "#/$defs/base_relative_path"
        }
      }
    },
    "bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_root",
        "deck_path",
        "spec_path",
        "doc_paths",
        "image_paths",
        "report_paths",
        "preview_paths"
      ],
      "properties": {
        "project_root": {
          "$ref": "#/$defs/base_relative_path"
        },
        "deck_path": {
          "$ref": "#/$defs/base_relative_path"
        },
        "spec_path": {
          "$ref": "#/$defs/base_relative_path"
        },
        "doc_paths": {
          "$ref": "#/$defs/base_relative_path_list"
        },
        "image_paths": {
          "$ref": "#/$defs/base_relative_path_list"
        },
        "report_paths": {
          "$ref": "#/$defs/base_relative_path_list"
        },
        "preview_paths": {
          "$ref": "#/$defs/base_relative_path_list"
        }
      }
    },
    "validation_results": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "known_caveats": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reference_capture": {
      "type": ["object", "null"],
      "additionalProperties": true
    }
  },
  "$defs": {
    "base_relative_path": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "^(?:[A-Za-z]:|/|\\\\|\\.\\.)"
      },
      "pattern": "^[^\\\\]+$"
    },
    "base_relative_path_list": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/base_relative_path"
      }
    }
  }
}
